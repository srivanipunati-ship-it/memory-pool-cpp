#include <iostream>
using namespace std;

struct book{
    bool used=false;
    char data[0];
    
};
book pool[1000];

int allocate(){
    for(int i=0;i<1000;i++){
        if(pool[i].used==false){
            pool[i].used=true;
            cout<<"Avialable slots"<<i<<endl;
            return i;
            
        }
    }
    return -1;
}
void disallocate(int i){
    pool[i].used=false;
    cout<<"avaible dis allocates"<<i<<endl;
}
int main(){
   int slot=allocate();
   disallocate(slot);
  
    
}
